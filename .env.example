# DamZone — omgevingsvariabelen (kopieer naar .env en vul in)
# Zie ook .env.development / .env.test / .env.acceptance / .env.production

# Database (SQLite voor dev/test, PostgreSQL voor acceptatie/productie)
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT geheim — minimaal 32 willekeurige tekens in productie
JWT_SECRET="vervang-dit-door-een-lang-willekeurig-geheim"

# Toegestane CORS-origin (frontend-URL)
CORS_ORIGIN="http://localhost:5173"

# Serverpoort
PORT=3001
